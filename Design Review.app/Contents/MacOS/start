#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/../../../" && pwd)"

# Read token from Keychain (no Documents folder permission needed)
TOKEN=$(security find-generic-password -a "$USER" -s "DesignReview-FigmaToken" -w 2>/dev/null)

if [ -z "$TOKEN" ]; then
  TOKEN=$(osascript <<'APPLESCRIPT'
    set theResult to display dialog "Paste your Figma API token to get started:" \
      default answer "" \
      with title "Design Review — First Time Setup" \
      buttons {"Cancel", "Save"} \
      default button "Save"
    return text returned of theResult
APPLESCRIPT
  )

  if [ -z "$TOKEN" ]; then
    exit 0
  fi

  # Save to Keychain
  security add-generic-password -a "$USER" -s "DesignReview-FigmaToken" -w "$TOKEN" 2>/dev/null || \
  security add-generic-password -a "$USER" -s "DesignReview-FigmaToken" -w "$TOKEN" -U 2>/dev/null

  osascript -e 'display notification "Token saved. You are ready to go!" with title "Design Review"'
fi

# Open Chrome with debug port (separate profile, existing Chrome stays open)
/Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome \
  --remote-debugging-port=9222 \
  --user-data-dir=/tmp/chrome-dr \
  --no-first-run \
  --no-default-browser-check &

# Open Terminal with Claude Code running inside it
osascript <<APPLESCRIPT
tell application "Terminal"
  do script "cd '$PROJECT_DIR' && claude ."
  activate
end tell
APPLESCRIPT
